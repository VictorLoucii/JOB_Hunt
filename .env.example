# ============================================================
# JobHunt — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is gitignored.
# ============================================================

# ---- OpenRouter (LLM) ----
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ---- Server ----
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
LOG_LEVEL=INFO

# ---- Gmail OAuth ----
# Path to your Google Cloud OAuth credentials file
GMAIL_CREDENTIALS_PATH=./credentials/credentials.json
# Path where the OAuth token will be saved after first auth
GMAIL_TOKEN_PATH=./credentials/token.json

# ---- Resume ----
# Directory where your resume PDF is stored
RESUME_DIR=~/Documents/resumes/
